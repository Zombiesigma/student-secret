rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gunturfadilah140@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidSecret(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.category is string && data.category.size() > 0 &&
             data.likes is number &&
             data.color is string &&
             data.timestamp is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /survey_responses/{responseId} {
      allow read: if isAdmin();
      allow create: if true; // Anonymous responses
    }

    match /secrets/{secretId} {
      allow read: if true;
      allow create: if isValidSecret(request.resource.data);
      allow update: if (isValidSecret(request.resource.data) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'commentCount'])) || isAdmin();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.resource.data.content is string && 
                         request.resource.data.content.size() > 0 &&
                         request.resource.data.content.size() <= 500 &&
                         request.resource.data.likes == 0;
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
                         request.resource.data.likes == resource.data.likes + 1;
        allow delete: if isAdmin();
      }
    }

    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.targetId is string &&
                       request.resource.data.targetType in ['secret', 'comment'] &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.timestamp is number;
    }
  }
}
